{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@authentication/*": ["src/bounded-contexts/authentication/*"],
      "@user/*": ["src/bounded-contexts/user/*"],
      "@shared/*": ["src/shared/*"],
      "@common/*": ["src/common/*"],
      "@core/*": ["src/core/*"],
      "@test/*": ["test/*"],
      "@tenant/*": ["src/bounded-contexts/tenant/*"],
      "@test-mockup/*": ["test/__mocks__/*"],
      "@storage/*": ["src/bounded-contexts/storage/*"],
      "@onboarding/*": ["src/bounded-contexts/onboarding/*"],
      "@authorization/*": ["src/bounded-contexts/authorization/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "test/__mocks__/*"],
  "exclude": ["node_modules", "dist"]
}
