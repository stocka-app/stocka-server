NODE_ENV=development
PORT=3001
API_PREFIX=api
FRONTEND_URL=http://localhost:5173
REQUEST_TIMEOUT_MS=10000

DB_HOST=localhost
DB_PORT=5434  # Docker dev: maps host 5434 → container 5432 (see docker/docker-compose.dev.yml)
DB_USERNAME=stocka
DB_PASSWORD=stocka_dev_password
DB_DATABASE=stocka_db

JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

CORS_ORIGIN=http://localhost:5173

# ============================================
# FEATURE FLAGS - SOCIAL AUTH PROVIDERS
# ============================================
GOOGLE_AUTH_ENABLED=true
FACEBOOK_AUTH_ENABLED=true
MICROSOFT_AUTH_ENABLED=true
APPLE_AUTH_ENABLED=false

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ============================================
# FACEBOOK OAUTH
# ============================================
# Obtener en: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

# ============================================
# MICROSOFT OAUTH (Azure AD)
# ============================================
# Obtener en: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/auth/microsoft/callback

# ============================================
# APPLE SIGN-IN (DISABLED - See ADR-001)
# ============================================
# Documentado para reactivación futura cuando se publique en App Store
# Obtener en: https://developer.apple.com/account/resources/identifiers
# APPLE_CLIENT_ID=com.stocka.app
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=Stocka <noreply@stocka.app>
VERIFICATION_CODE_EXPIRATION_MINUTES=10
