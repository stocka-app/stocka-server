NODE_ENV=development
PORT=3001
API_PREFIX=api
FRONTEND_URL=http://localhost:5173
REQUEST_TIMEOUT_MS=10000

DB_HOST=localhost
DB_PORT=5434  # Docker dev: maps host 5434 → container 5432 (see docker/docker-compose.dev.yml)
DB_USERNAME=stocka
DB_PASSWORD=stocka_dev_password
DB_DATABASE=stocka_db

JWT_ACCESS_SECRET=your-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Required: HMAC-SHA256 key for OAuth state signing (prevents CSRF in OAuth flows)
OAUTH_STATE_SECRET=your-oauth-state-secret-minimum-32-characters

CORS_ORIGIN=http://localhost:5173

# ============================================
# FEATURE FLAGS - SOCIAL AUTH PROVIDERS
# ============================================
GOOGLE_AUTHENTICATION_ENABLED=true
FACEBOOK_AUTHENTICATION_ENABLED=false
MICROSOFT_AUTHENTICATION_ENABLED=true
APPLE_AUTHENTICATION_ENABLED=false

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/authentication/google/callback

# ============================================
# FACEBOOK OAUTH (DISABLED - No email guarantee)
# ============================================
# Facebook no garantiza email — usuarios pueden registrarse solo con número celular.
# Desactivado para mantener integridad del modelo de identidad (email obligatorio).
# Reactivar solo si se implementa un flujo de recuperación de identidad alternativo.
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_CALLBACK_URL=http://localhost:3001/api/authentication/facebook/callback

# ============================================
# MICROSOFT OAUTH (Azure AD)
# ============================================
# Obtener en: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:3001/api/authentication/microsoft/callback

# ============================================
# APPLE SIGN-IN (DISABLED - See ADR-001)
# ============================================
# Documentado para reactivación futura cuando se publique en App Store
# Obtener en: https://developer.apple.com/account/resources/identifiers
# APPLE_CLIENT_ID=com.stocka.app
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_CALLBACK_URL=http://localhost:3001/api/authentication/apple/callback

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=Stocka <noreply@stocka.app>
VERIFICATION_CODE_EXPIRATION_MINUTES=10

# ============================================
# BILLING / STRIPE
# ============================================
# Test Mode keys — obtener en: https://dashboard.stripe.com/test/apikeys
# Para producción usar las claves de Live Mode (dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret — obtener al crear el endpoint en Stripe Dashboard
# o usando `stripe listen` (Stripe CLI) para forwarding local
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs por tier — obtener al crear los Products en Stripe Dashboard
# Solo STARTER y GROWTH son purchasable (FREE no tiene Stripe Product, ENTERPRISE es sales-led)
STRIPE_PRICE_ID_STARTER_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_ID_GROWTH_MONTHLY=price_REPLACE_ME

# Product IDs por tier — obtener del Stripe Dashboard (Product → ID en la URL o en el detail)
# Necesarios para guardar en provider_price_mappings (audit + scripts de mantenimiento futuros)
STRIPE_PRODUCT_ID_STARTER=prod_REPLACE_ME
STRIPE_PRODUCT_ID_GROWTH=prod_REPLACE_ME

# Paths de retorno — usados por Stripe Checkout y Customer Portal
# Solo el path (sin host). El host se toma de FRONTEND_URL en runtime.
# Deben empezar con "/".
STRIPE_CUSTOMER_PORTAL_RETURN_PATH=/settings/billing
STRIPE_CHECKOUT_SUCCESS_PATH=/billing/success
STRIPE_CHECKOUT_CANCEL_PATH=/billing/cancelled
