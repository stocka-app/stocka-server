{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@authentication/*": ["src/bounded-contexts/authentication/*"],
      "@user/*": ["src/bounded-contexts/user/*"],
      "@shared/*": ["src/shared/*"],
      "@common/*": ["src/common/*"],
      "@core/*": ["src/core/*"],
      "@test/*": ["test/*"],
      "@test-mockup/*": ["test/__mocks__/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "test/__mocks__/*"]
}
