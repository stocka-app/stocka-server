{
  "name": "stocka-server",
  "version": "0.20.0",
  "description": "Stocka inventory management system API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:setup:debug": "npm run typeorm:db:drop && npm run typeorm:migration:run && npm run start:debug",
    "start:e2e": "cross-env PORT=3002 DB_DATABASE=stocka_playwright E2E_MODE=true nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathPatterns=test/unit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.js --forceExit",
    "test:e2e:seq": "jest --config ./test/jest-e2e.js --runInBand --forceExit",
    "test:e2e:cov": "jest --config ./test/jest-e2e.js --coverage --runInBand --forceExit",
    "pretest:e2e": "node scripts/check-env.js",
    "pretest:e2e:cov": "node scripts/check-env.js",
    "test:e2e:fast": "jest --config ./test/jest-e2e.js --testPathIgnorePatterns=infra-repository --forceExit",
    "test:e2e:infra": "jest --config ./test/jest-e2e.js --testPathPatterns=infra-repository --runInBand --forceExit",
    "test:cov:all": "npm run test:cov && npm run test:e2e:cov && node scripts/merge-coverage.js",
    "coverage:merge": "node scripts/merge-coverage.js",
    "release": "release-it",
    "release:preview": "release-it --dry-run --no-git.requireBranch",
    "release:notes": "RELEASE_IT_AUTO=1 release-it --ci --no-git.push && echo 'Edit CHANGELOG.md, then: git commit --amend --no-edit'",
    "prepare": "git config core.hooksPath .githooks",
    "typeorm": "npx ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js",
    "typeorm:migration:generate": "npm run typeorm -- migration:generate -d src/core/config/database/data-source.ts",
    "typeorm:migration:run": "npm run typeorm -- migration:run -d src/core/config/database/data-source.ts",
    "typeorm:migration:revert": "npm run typeorm -- migration:revert -d src/core/config/database/data-source.ts",
    "typeorm:seed:run": "npm run typeorm -- migration:run -d src/core/config/database/seed-source.ts",
    "typeorm:seed:revert": "npm run typeorm -- migration:revert -d src/core/config/database/seed-source.ts",
    "typeorm:db:drop": "npm run db:reset && npm run typeorm:seed:run",
    "typeorm:db:reset": "npx ts-node -r tsconfig-paths/register scripts/db-soft-reset.ts",
    "docker:dev": "docker compose -f docker/docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker/docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker/docker-compose.dev.yml down",
    "docker:prod": "docker compose -f docker/docker-compose.yml up -d",
    "docker:prod:build": "docker compose -f docker/docker-compose.yml up -d --build",
    "docker:prod:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:db": "docker compose -f docker/docker-compose.dev.yml up postgres",
    "docker:clean:cache": "docker builder prune -f",
    "docker:clean:volumes": "docker volume prune -f",
    "docker:clean:all": "docker system prune -f --volumes",
    "env:check": "node scripts/check-env.js",
    "db:reset": "npx ts-node -r tsconfig-paths/register scripts/db-reset.ts"
  },
  "dependencies": {
    "@arendajaelu/nestjs-passport-apple": "^2.0.5",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@react-email/components": "^1.0.7",
    "@react-email/render": "^2.0.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "neverthrow": "^8.2.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-microsoft": "^2.1.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-microsoft": "^2.1.1",
    "@types/react": "^19.2.13",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.4.0",
    "jest": "^30.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.4.2",
    "release-it": "^19.2.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
